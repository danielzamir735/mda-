# Copy this file to .env.local and fill in your Supabase project values.
# Never commit .env or .env.local to version control.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Web Push (Daily Push feature) — public key only. Generate a pair with
# `npx web-push generate-vapid-keys` and set the private key as the
# VAPID_PRIVATE_KEY secret on the send-daily-push edge function — never here.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here
